generator client {
  provider = "prisma-client"
  output   = "./src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  createdAt DateTime @default(now())
}

model BonVendange {
  id        Int       @id @default(autoincrement())
  remorque  String
  parcelle  String
  sepage    String
  millesime Int
  cuve      String?
  status    String    @default("EN_COURS")

  palettes  Palette[]
  cagettes  Cagette[]

  createdAt DateTime  @default(now())
  createdBy       String
  createdWithRole String
  updatedAt DateTime  @updatedAt
  updatedBy       String?
  updatedWithRole String?

  logs      HistoriqueBon[]
}

model Palette {
  id            Int         @id @default(autoincrement())
  number        Int
  
  bonVendangeId Int
  bonVendange   BonVendange @relation(fields: [bonVendangeId], references: [id])
  
  cagettes      Cagette[]

  createdAt DateTime  @default(now())
  createdBy       String
  createdWithRole String
  updatedAt DateTime  @updatedAt
  updatedBy       String?
  updatedWithRole String?

  @@unique([number, bonVendangeId])
}

model Cagette {
  id            Int         @id @default(autoincrement())
  number        Int
  poids         Float
  
  paletteId     Int
  palette       Palette     @relation(fields: [paletteId], references: [id])

  bonVendangeId Int
  bonVendange   BonVendange @relation(fields: [bonVendangeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime  @default(now())
  createdBy       String
  createdWithRole String
  updatedAt DateTime  @updatedAt
  updatedBy       String?
  updatedWithRole String?

  @@unique([number, bonVendangeId])
}

model HistoriqueBon {
  id              Int          @id @default(autoincrement())
  action          String       // ex: "CREATION", "MODIFICATION_CUVE", "CLOTURE"
  details         String       // Un texte descriptif ou du JSON (ex: "Cuve modifiée : Cuve Inox A3")
  createdAt       DateTime     @default(now())
  
  // Informations de l'auteur de l'action (issues du Token JWT)
  username        String       // ex: "op.test"
  role            String       // ex: "OPERATEUR"

  // Liaison avec le bon de vendange concerné
  bonVendangeId   Int
  bonVendange     BonVendange  @relation(fields: [bonVendangeId], references: [id], onDelete: Cascade)
}